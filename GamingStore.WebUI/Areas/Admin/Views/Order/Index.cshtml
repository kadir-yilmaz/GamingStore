@model IEnumerable<Order>
@{
    ViewData["Title"] = "Sipariş Yönetimi";
    Layout = "_Layout";
}

<div class="container-fluid py-4">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="mb-1"><i class="fas fa-shopping-cart me-2 text-primary"></i>Sipariş Yönetimi</h2>
            <p class="text-muted mb-0">Tüm siparişleri görüntüleyin ve süreçleri yönetin</p>
        </div>
        <div class="d-flex gap-2">
            <button class="btn btn-outline-primary" onclick="filterOrders('all')">
                <i class="fas fa-list me-1"></i> Tümü (@Model.Count())
            </button>
            <button class="btn btn-outline-warning" onclick="filterOrders('pending')">
                <i class="fas fa-clock me-1"></i> Sipariş Alındı (@Model.Count(x => x.Status == OrderStatus.Pending))
            </button>
            <button class="btn btn-outline-info" onclick="filterOrders('shipped')">
                <i class="fas fa-truck me-1"></i> Kargoda (@Model.Count(x => x.Status == OrderStatus.Shipped))
            </button>
        </div>
    </div>

    <!-- Orders Grid -->
    <div class="row g-3" id="ordersContainer">
        @if (Model != null && Model.Any())
        {
            foreach (var order in Model)
            {
                var statusClass = order.Status switch
                {
                    OrderStatus.Pending => "warning",
                    OrderStatus.Completed => "success",
                    OrderStatus.Failed => "danger",
                    OrderStatus.Processing => "primary",
                    OrderStatus.Shipped => "info",
                    OrderStatus.Delivered => "success",
                    _ => "secondary"
                };

                var statusText = order.Status switch
                {
                    OrderStatus.Pending => "Sipariş Alındı",
                    OrderStatus.Completed => "Ödeme Tamamlandı",
                    OrderStatus.Failed => "İptal Edildi",
                    OrderStatus.Processing => "Hazırlanıyor",
                    OrderStatus.Shipped => "Kargoda",
                    OrderStatus.Delivered => "Teslim Edildi",
                    _ => "Bilinmiyor"
                };

                var statusIcon = order.Status switch
                {
                    OrderStatus.Pending => "fa-clock",
                    OrderStatus.Completed => "fa-check-circle",
                    OrderStatus.Failed => "fa-times-circle",
                    OrderStatus.Processing => "fa-cog fa-spin",
                    OrderStatus.Shipped => "fa-truck",
                    OrderStatus.Delivered => "fa-box-open",
                    _ => "fa-question"
                };

                <div class="col-12 order-card" data-status="@((int)order.Status)">
                    <div class="card shadow-sm border-0 h-100 hover-card mb-3">
                        <div class="card-body">
                            <div class="row align-items-center">
                                <!-- Sipariş Bilgileri -->
                                <div class="col-md-2">
                                    <div class="text-center border-end">
                                        <h5 class="mb-1 text-primary">#@order.Id</h5>
                                        <small class="text-muted">
                                            @order.OrderedAt.ToString("dd.MM.yyyy")<br/>
                                            @order.OrderedAt.ToString("HH:mm")
                                        </small>
                                    </div>
                                </div>

                                <!-- Müşteri Bilgileri -->
                                <div class="col-md-2">
                                    <div>
                                        <i class="fas fa-user text-muted me-1"></i>
                                        <strong>@order.ShippingFirstName @order.ShippingLastName</strong>
                                    </div>
                                    <small class="text-muted d-block">
                                        <i class="fas fa-phone me-1"></i>@order.ShippingPhone
                                    </small>
                                    <small class="text-muted">
                                        <i class="fas fa-map-marker-alt me-1"></i>@order.ShippingProvince / @order.ShippingDistrict
                                    </small>
                                </div>

                                <!-- Ürünler -->
                                <div class="col-md-3">
                                    <div class="product-list">
                                        @foreach (var item in order.Lines.Take(2))
                                        {
                                            <div class="mb-1">
                                                <small class="text-truncate d-block">
                                                    <i class="fas fa-box text-muted me-1"></i>@item.Product.Name (@item.Quantity adet)
                                                </small>
                                            </div>
                                        }
                                        @if (order.Lines.Count > 2)
                                        {
                                            <small class="text-muted">+@(order.Lines.Count - 2) ürün daha</small>
                                        }
                                    </div>
                                </div>

                                <!-- Toplam -->
                                <div class="col-md-2 text-center">
                                    <h4 class="mb-0 text-success">
                                        @order.Lines.Sum(x => x.Product.Price * x.Quantity).ToString("C2")
                                    </h4>
                                    <small class="text-muted">Toplam</small>
                                </div>

                                <!-- Durum -->
                                <div class="col-md-2 text-center">
                                    <span class="badge bg-@statusClass fs-6 px-3 py-2 w-100">
                                        <i class="fas @statusIcon me-1"></i>@statusText
                                    </span>
                                </div>

                                <!-- İşlemler -->
                                <div class="col-md-1 text-end">
                                    <div class="d-flex flex-column gap-1">
                                        @if (order.Status == OrderStatus.Pending || order.Status == OrderStatus.Completed) // Beklemede veya Ödeme tamamlandı
                                        {
                                            <button type="button" class="btn btn-primary btn-sm" onclick="showPrepareConfirm(@order.Id)">
                                                <i class="fas fa-cog me-1"></i> Hazırla
                                            </button>
                                        }
                                        @if (order.Status == OrderStatus.Processing) // Hazırlanıyor
                                        {
                                            <button type="button" class="btn btn-info text-white btn-sm" onclick="showShipModal(@order.Id)">
                                                <i class="fas fa-truck me-1"></i> Kargola
                                            </button>
                                        }
                                        @if (order.Status == OrderStatus.Shipped) // Kargoda
                                        {
                                            <button type="button" class="btn btn-success btn-sm" onclick="showDeliverConfirm(@order.Id)">
                                                <i class="fas fa-box-open me-1"></i> Teslim
                                            </button>
                                        }
                                        @if (order.Status != OrderStatus.Failed && order.Status != OrderStatus.Delivered)
                                        {
                                            <button type="button" class="btn btn-outline-danger btn-sm" onclick="showCancelConfirm(@order.Id)">
                                                <i class="fas fa-times me-1"></i> İptal
                                            </button>
                                        }
                                        <button type="button" class="btn btn-outline-secondary btn-sm" onclick="showOrderDetail(@order.Id)">
                                            <i class="fas fa-eye me-1"></i> Detay
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Kargolama Modal -->
                    <div class="modal fade" id="shipModal@(order.Id)" tabindex="-1">
                        <div class="modal-dialog">
                            <div class="modal-content">
                                <form asp-action="Ship" method="post">
                                    <div class="modal-header bg-info text-white">
                                        <h5 class="modal-title"><i class="fas fa-truck me-2"></i>Kargoya Ver - #@order.Id</h5>
                                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                                    </div>
                                    <div class="modal-body">
                                        <input type="hidden" name="orderId" value="@order.Id" />
                                        <div class="mb-3">
                                            <label class="form-label fw-bold">Kargo Firması</label>
                                            <select name="cargoCompany" class="form-select" required>
                                                <option value="">Seçiniz...</option>
                                                <option value="Yurtiçi Kargo">Yurtiçi Kargo</option>
                                                <option value="Aras Kargo">Aras Kargo</option>
                                                <option value="MNG Kargo">MNG Kargo</option>
                                                <option value="PTT Kargo">PTT Kargo</option>
                                                <option value="Sürat Kargo">Sürat Kargo</option>
                                            </select>
                                        </div>
                                        <div class="mb-3">
                                            <label class="form-label fw-bold">Takip Numarası</label>
                                            <input type="text" name="trackingNumber" class="form-control" required placeholder="Takip numarasını giriniz" />
                                        </div>
                                        <div class="card bg-light border-0">
                                            <div class="card-body">
                                                <h6 class="mb-1 suger-font">Teslimat Adresi:</h6>
                                                <p class="mb-0 small text-muted">@order.ShippingAddressDetail, @order.ShippingNeighborhood, @order.ShippingDistrict/@order.ShippingProvince</p>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="modal-footer">
                                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Vazgeç</button>
                                        <button type="submit" class="btn btn-info text-white">Kargoya Ver</button>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>

                    <!-- Detay Modal -->
                    <div class="modal fade" id="detailModal@(order.Id)" tabindex="-1">
                        <div class="modal-dialog modal-lg">
                            <div class="modal-content">
                                <div class="modal-header bg-dark text-white">
                                    <h5 class="modal-title">Sipariş Detayı - #@order.Id</h5>
                                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                                </div>
                                <div class="modal-body">
                                    <div class="row mb-4">
                                        <div class="col-md-6">
                                            <h6><i class="fas fa-user me-2"></i>Müşteri & İletişim</h6>
                                            <p class="mb-1"><strong>Ad Soyad:</strong> @order.ShippingFirstName @order.ShippingLastName</p>
                                            <p class="mb-1"><strong>Telefon:</strong> @order.ShippingPhone</p>
                                        </div>
                                        <div class="col-md-6">
                                            <h6><i class="fas fa-map-marker-alt me-2"></i>Teslimat Adresi</h6>
                                            <p class="small">@order.ShippingAddressDetail, @order.ShippingNeighborhood, @order.ShippingDistrict/@order.ShippingProvince</p>
                                        </div>
                                    </div>
                                    <h6><i class="fas fa-boxes me-2"></i>Sipariş Ürünleri</h6>
                                    <table class="table table-sm table-hover border">
                                        <thead class="table-light">
                                            <tr>
                                                <th>Ürün</th>
                                                <th class="text-center">Adet</th>
                                                <th class="text-end">Fiyat</th>
                                                <th class="text-end">Toplam</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var line in order.Lines)
                                            {
                                                <tr>
                                                    <td>
                                                        <div class="d-flex align-items-center">
                                                            <img src="@line.Product.ImageURL" class="rounded border me-2" style="width: 40px; height: 40px; object-fit: contain; background: white;" alt="@line.Product.Name" />
                                                            <span>@line.Product.Name</span>
                                                        </div>
                                                    </td>
                                                    <td class="text-center">@line.Quantity</td>
                                                    <td class="text-end">@line.Product.Price.ToString("C2")</td>
                                                    <td class="text-end">@((line.Product.Price * line.Quantity).ToString("C2"))</td>
                                                </tr>
                                            }
                                        </tbody>
                                        <tfoot>
                                            <tr class="fw-bold fs-5">
                                                <td colspan="3" class="text-end">GENEL TOPLAM:</td>
                                                <td class="text-end text-success">@order.Lines.Sum(x => x.Product.Price * x.Quantity).ToString("C2")</td>
                                            </tr>
                                        </tfoot>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12 text-center py-5">
                <i class="fas fa-box-open fa-4x text-muted mb-3"></i>
                <p class="lead text-muted">Henüz sipariş bulunamadı.</p>
            </div>
        }
    </div>
</div>

<!-- Durum Güncelleme Formu (Hidden) -->
<form id="statusUpdateForm" asp-action="UpdateStatus" method="post" style="display:none;">
    <input type="hidden" name="orderId" id="statusOrderId" />
    <input type="hidden" name="status" id="statusValue" />
</form>

<!-- Sipariş İptal Formu (Hidden) -->
<form id="cancelOrderForm" asp-action="Delete" method="post" style="display:none;">
    <input type="hidden" name="id" id="cancelOrderId" />
</form>

<style>
    .hover-card { transition: all 0.3s ease; }
    .hover-card:hover { transform: translateY(-3px); box-shadow: 0 5px 15px rgba(0,0,0,0.1) !important; }
    .product-list { max-height: 50px; overflow: hidden; }
    .hidden { display: none; }
</style>

<script>
    function showPrepareConfirm(id) {
        if (confirm('Siparişi hazırlamaya başlamak istiyor musunuz?')) {
            document.getElementById('statusOrderId').value = id;
            document.getElementById('statusValue').value = 3; // Processing
            document.getElementById('statusUpdateForm').submit();
        }
    }

    function showShipModal(id) {
        var modal = new bootstrap.Modal(document.getElementById('shipModal' + id));
        modal.show();
    }

    function showDeliverConfirm(id) {
        if (confirm('Siparişi teslim edildi olarak işaretlemek istiyor musunuz?')) {
            document.getElementById('statusOrderId').value = id;
            document.getElementById('statusValue').value = 5; // Delivered
            document.getElementById('statusUpdateForm').submit();
        }
    }

    function showCancelConfirm(id) {
        if (confirm('Siparişi iptal etmek istediğinizden emin misiniz?')) {
            document.getElementById('cancelOrderId').value = id;
            document.getElementById('cancelOrderForm').submit();
        }
    }

    function showOrderDetail(id) {
        var modal = new bootstrap.Modal(document.getElementById('detailModal' + id));
        modal.show();
    }

    function filterOrders(status) {
        const cards = document.querySelectorAll('.order-card');
        cards.forEach(card => {
            if (status === 'all') {
                card.classList.remove('hidden');
            } else if (status === 'pending' && card.getAttribute('data-status') == '0') {
                card.classList.remove('hidden');
            } else if (status === 'shipped' && card.getAttribute('data-status') == '4') {
                card.classList.remove('hidden');
            } else {
                card.classList.add('hidden');
            }
        });
    }
</script>