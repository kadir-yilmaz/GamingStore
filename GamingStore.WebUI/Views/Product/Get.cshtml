@model Product

<div class="container my-4">
    <div class="row">
        <!-- Sol: Ürün Görseli -->
        <div class="col-lg-6 text-center">
            <img class="img-fluid shadow rounded-3" src="@Model?.ImageURL" alt="@Model.Name" style="max-height: 400px; object-fit: contain;" />
        </div>

        <!-- Sağ: Ürün Bilgileri -->
        <div class="col-lg-6">
            <h2 class="mb-3">@Model.Name</h2>
            <p class="lead text-dark fw-bold mb-3">@Model.Price.ToString("C")</p>

            <!-- Stok bilgisi -->
            <p class="mb-3">
                <strong>Stok Durumu:</strong>
                @if (Model.Stock > 0)
                {
                    <span class="text-success">@Model.Stock adet</span>
                }
                else
                {
                    <span class="text-danger">Tükendi</span>
                }
            </p>

            @if (Model.Stock > 0)
            {
                <form id="addToCartForm-@Model.Id" asp-page="/cart" method="post" class="mb-3">
                    <input type="hidden" name="productId" value="@Model.Id" />
@*                     <input type="hidden" name="returnUrl" value="@ViewContext.HttpContext.Request.PathAndQuery()" />
 *@                    <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />
                    <button type="submit" class="btn btn-primary btn-lg w-100 d-flex justify-content-center align-items-center">
                        <i class="fa fa-cart-plus me-2"></i> Sepete Ekle
                    </button>
                </form>
            }
            else
            {
                <button class="btn btn-secondary btn-lg w-100 d-flex justify-content-center align-items-center" disabled>
                    <i class="fa fa-ban me-2"></i> Stokta Yok
                </button>
            }

            <!-- Genel Özellikler (Summary) -->
            <div class="mb-3">
                <h5>Genel Özellikler</h5>
                <p style="white-space: pre-line;">@Model.Summary</p>
            </div>

        </div>
    </div>

    <!-- Sekmeler: Taksit / Yorumlar -->
    <div class="row mt-4">
        <div class="col-12">
            <ul class="nav nav-tabs" id="productTab" role="tablist">
                <li class="nav-item" role="presentation">
                    <button class="nav-link active" id="installment-tab" data-bs-toggle="tab" data-bs-target="#installment" type="button" role="tab">
                        Taksit Seçenekleri
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link" id="reviews-tab" data-bs-toggle="tab" data-bs-target="#reviews" type="button" role="tab">
                        Yorumlar
                    </button>
                </li>
            </ul>

            <div class="tab-content p-3 border border-top-0 rounded-bottom" id="productTabContent">
                <!-- Taksit Seçenekleri -->
                <div class="tab-pane fade show active" id="installment" role="tabpanel">
                    <ul>
                        <li>3 Taksit: @((Model.Price / 3).ToString("C"))</li>
                        <li>6 Taksit: @((Model.Price / 6).ToString("C"))</li>
                        <li>12 Taksit: @((Model.Price / 12).ToString("C"))</li>
                    </ul>
                </div>

                <!-- Yorumlar -->
                <div class="tab-pane fade" id="reviews" role="tabpanel">
                    <div class="mb-2">
                        <strong>Kadir Yılmaz</strong>
                        <p>Ürün çok kaliteli ve hızlı teslimat!</p>
                    </div>
                    <div class="mb-2">
                        <strong>Ayşe Demir</strong>
                        <p>Fiyatına göre performansı mükemmel.</p>
                    </div>

                    <!-- Yorum ekleme formu -->
                    <form class="mt-3">
                        <div class="mb-2">
                            <label for="reviewText" class="form-label">Yeni Yorum</label>
                            <textarea class="form-control" id="reviewText" rows="3" placeholder="Yorumunuzu yazın..."></textarea>
                        </div>
                        <button type="submit" class="btn btn-outline-primary">Gönder</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
