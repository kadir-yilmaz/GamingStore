@model LoginModel
@{
    ViewData["Title"] = "Giriş Yap";
}

<style>
    .hepsiburada-orange {
        color: #ff6000;
    }

    .btn-hepsi {
        background-color: #ff6000;
        border-color: #ff6000;
        color: white;
        font-weight: 500;
        padding: 12px 24px;
        border-radius: 6px;
    }

        .btn-hepsi:hover {
            background-color: #e55500;
            border-color: #e55500;
            color: white;
        }

    .login-container {
        background: white;
        border-radius: 12px;
        box-shadow: 0 2px 20px rgba(0,0,0,0.1);
        overflow: hidden;
        max-width: 500px;
        margin: 50px auto;
    }

    .tab-container {
        display: flex;
        border-bottom: 2px solid #f0f0f0;
    }

    .tab {
        flex: 1;
        padding: 20px;
        text-align: center;
        cursor: pointer;
        background: #f8f9fa;
        border: none;
        font-weight: 500;
        color: #666;
        transition: all 0.3s ease;
    }

        .tab.active {
            background: white;
            color: #ff6000;
            border-bottom: 3px solid #ff6000;
        }

    .form-container {
        padding: 30px;
    }

    .form-control {
        padding: 12px 16px;
        border: 1px solid #ddd;
        border-radius: 6px;
        margin-bottom: 15px;
        font-size: 14px;
    }

        .form-control:focus {
            border-color: #ff6000;
            box-shadow: 0 0 0 0.2rem rgba(255, 96, 0, 0.25);
        }

    .form-label {
        color: #333;
        font-weight: 500;
        margin-bottom: 8px;
    }

    .social-login {
        margin-top: 30px;
        text-align: center;
    }

    .social-btn {
        width: 50px;
        height: 50px;
        border-radius: 8px;
        border: 1px solid #ddd;
        background: white;
        margin: 0 10px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 20px;
        color: #666;
        transition: all 0.3s ease;
    }

        .social-btn:hover {
            background: #f8f9fa;
            border-color: #ccc;
        }

    .forgot-password {
        color: #ff6000;
        text-decoration: none;
        font-size: 14px;
    }

        .forgot-password:hover {
            color: #e55500;
            text-decoration: underline;
        }

    .phone-login {
        background: white;
        border: 1px solid #ff6000;
        color: #ff6000;
        padding: 12px 24px;
        border-radius: 6px;
        width: 100%;
        margin-top: 15px;
        font-weight: 500;
    }

        .phone-login:hover {
            background: #ff6000;
            color: white;
        }

    .privacy-text {
        font-size: 12px;
        color: #666;
        line-height: 1.4;
        margin-top: 15px;
    }

        .privacy-text a {
            color: #ff6000;
            text-decoration: none;
        }

            .privacy-text a:hover {
                text-decoration: underline;
            }

    .header-logo {
        text-align: center;
        padding: 20px 0;
    }

    .logo {
        font-size: 32px;
        font-weight: bold;
        color: #ff6000;
        text-decoration: none;
    }
</style>

<div class="container">
    <div class="header-logo">
        <a href="/" class="logo">Gaming Store</a>
    </div>

    <div class="login-container">
        <div class="tab-container">
            <button class="tab active" id="loginTab" onclick="showTab('login')">Giriş yap</button>
            <button class="tab" id="registerTab" onclick="showTab('register')">Üye ol</button>
        </div>

        <!-- Login Form -->
        <div id="loginForm" class="form-container">
            <div class="text-danger" asp-validation-summary="All"></div>

            <form method="post" asp-action="Login">
                <input type="hidden" asp-for="ReturnUrl" />

                <div class="mb-3">
                    <label asp-for="Email" class="form-label">E-posta adresi</label>
                    <input asp-for="Email" class="form-control" placeholder="E-posta adresinizi girin" />
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Password" class="form-label">Şifre</label>
                    <input type="password" asp-for="Password" class="form-control" placeholder="Şifrenizi girin" />
                    <span asp-validation-for="Password" class="text-danger"></span>
                </div>

                <div class="mb-3 d-flex justify-content-between align-items-center gap-3 flex-wrap">
                    <div class="form-check m-0">
                        <input asp-for="RememberMe" class="form-check-input" />
                        <label asp-for="RememberMe" class="form-check-label">Beni hatırla</label>
                    </div>
                    <a href="#" class="forgot-password">Şifremi unuttum</a>
                </div>

                <button type="submit" class="btn btn-hepsi w-100">
                    <i class="fa-solid fa-right-to-bracket me-2"></i>
                    Giriş yap
                </button>


            </form>

            <div class="social-login">
                <p style="color: #666; margin-bottom: 20px;">Google ile giriş yap</p>
                <button class="social-btn">
                    <i class="fab fa-google"></i>
                </button>
            </div>
        </div>

        <!-- Register Form -->
        <div id="registerForm" class="form-container" style="display: none;">
            <form method="post" asp-action="Register">
                <div class="mb-3">
                    <label class="form-label">E-posta adresi</label>
                    <input name="Email" class="form-control" type="email" placeholder="E-posta adresinizi girin" required />
                </div>

                <div class="mb-3">
                    <label class="form-label">Şifre</label>
                    <div class="position-relative">
                        <input name="Password" class="form-control" type="password" id="registerPassword" placeholder="Şifrenizi oluşturun" required />
                        <button type="button" class="btn btn-link position-absolute end-0 top-50 translate-middle-y pe-3" onclick="togglePassword('registerPassword')" style="z-index: 10;">
                            <i class="fas fa-eye text-muted"></i>
                        </button>
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label">Şifre Tekrarı</label>
                    <div class="position-relative">
                        <input name="ConfirmPassword" class="form-control" type="password" id="confirmPassword" placeholder="Şifrenizi tekrar girin" required />
                        <button type="button" class="btn btn-link position-absolute end-0 top-50 translate-middle-y pe-3" onclick="togglePassword('confirmPassword')" style="z-index: 10;">
                            <i class="fas fa-eye text-muted"></i>
                        </button>
                    </div>
                </div>

                <button type="submit" class="btn btn-hepsi w-100">
                    Devam et
                </button>

            </form>

            <div class="social-login">
                <p style="color: #666; margin-bottom: 20px;">Google ile giriş yap</p>
                <button class="social-btn">
                    <i class="fab fa-google"></i>
                </button>
            </div>
        </div>
    </div>
</div>

<script>
    function showTab(tab) {
        const loginTab = document.getElementById('loginTab');
        const registerTab = document.getElementById('registerTab');
        const loginForm = document.getElementById('loginForm');
        const registerForm = document.getElementById('registerForm');

        if (tab === 'login') {
            loginTab.classList.add('active');
            registerTab.classList.remove('active');
            loginForm.style.display = 'block';
            registerForm.style.display = 'none';
        } else {
            registerTab.classList.add('active');
            loginTab.classList.remove('active');
            registerForm.style.display = 'block';
            loginForm.style.display = 'none';
        }
    }

    function togglePassword(inputId) {
        const input = document.getElementById(inputId);
        const icon = input.nextElementSibling.querySelector('i');

        if (input.type === 'password') {
            input.type = 'text';
            icon.className = 'fas fa-eye-slash text-muted';
        } else {
            input.type = 'password';
            icon.className = 'fas fa-eye text-muted';
        }
    }
</script>
