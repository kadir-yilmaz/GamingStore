@model IEnumerable<GamingStore.EL.Models.Order>

@{
    ViewData["Title"] = "Geçmiş Siparişlerim";
}

<div class="container my-5">
    <div class="row">
        <div class="col-12">
            <h2 class="mb-4"><i class="fa-solid fa-clock-rotate-left me-2 text-primary"></i>Geçmiş Siparişlerim</h2>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info d-flex align-items-center" role="alert">
            <i class="fa-solid fa-circle-info fa-lg me-3"></i>
            <div>
                Henüz hiç sipariş vermediniz.
                <a asp-controller="Home" asp-action="Index" class="alert-link ms-2">Alışverişe Başla</a>
            </div>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var order in Model)
            {
                <div class="col-12">
                    <div class="card shadow-sm border-0">
                        <div class="card-header bg-white border-bottom py-3">
                            <div class="row align-items-center">
                                <div class="col-md-4 mb-2 mb-md-0">
                                    <span class="text-muted small d-block">Sipariş Tarihi</span>
                                    <span class="fw-bold">@order.OrderedAt.ToString("dd MMMM yyyy HH:mm")</span>
                                </div>
                                <div class="col-md-4 mb-2 mb-md-0">
                                    <span class="text-muted small d-block">Sipariş Özeti</span>
                                    <span class="fw-bold">@order.Lines.Count() Ürün</span>
                                </div>
                                <div class="col-md-4 text-md-end">
                                    <span class="text-muted small d-block">Toplam Tutar</span>
                                    <span class="fw-bold text-success fs-5">@order.Lines.Sum(l => l.Product.Price *
                                l.Quantity).ToString("C2")</span>
                                </div>
                            </div>
                        </div>
                        <div class="card-body">
                            <h6 class="card-title fw-bold mb-3">Teslimat Adresi:</h6>
                            <p class="card-text text-muted mb-4 small">
                                @order.ShippingFirstName @order.ShippingLastName<br />
                                @order.ShippingAddressDetail<br />
                                @order.ShippingDistrict / @order.ShippingProvince
                            </p>

                            <h6 class="card-title fw-bold mb-3">Ürünler:</h6>
                            <div class="table-responsive">
                                <table class="table table-borderless align-middle mb-0">
                                    <tbody>
                                        @foreach (var item in order.Lines)
                                        {
                                            <tr>
                                                <td style="width: 80px;">
                                                    <img src="/img/products/@item.Product.ImageURL" alt="@item.Product.Name"
                                                        class="img-fluid rounded" style="max-height: 60px; object-fit: contain;">
                                                </td>
                                                <td>
                                                    <a asp-controller="Product" asp-action="Get" asp-route-id="@item.Product.Id"
                                                        class="text-dark text-decoration-none fw-semibold">
                                                        @item.Product.Name
                                                    </a>
                                                    <div class="text-muted small">Adet: @item.Quantity</div>
                                                </td>
                                                <td class="text-end fw-bold">
                                                    @((item.Product.Price * item.Quantity).ToString("C2"))
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                        <div class="card-footer bg-white border-top py-3 text-end">
                            @if (order.Shipped)
                            {
                                <span class="badge bg-success me-2"><i class="fa-solid fa-check me-1"></i> Kargolandı</span>
                            }
                            else
                            {
                                <span class="badge bg-warning text-dark me-2"><i class="fa-solid fa-hourglass-half me-1"></i>
                                    Hazırlanıyor</span>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
