@model IEnumerable<GamingStore.EL.Models.Order>

@{
    ViewData["Title"] = "Geçmiş Siparişlerim";
}

<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="mb-0 fw-bold"><i class="fas fa-clock-rotate-left me-2 text-primary"></i>Siparişlerim</h2>
        <a href="/" class="btn btn-outline-primary btn-sm rounded-pill px-3 fw-bold"><i class="fas fa-shopping-cart me-1"></i> Alışverişe Devam Et</a>
    </div>

    @if (Model != null && Model.Any())
    {
        foreach (var order in Model)
        {
            var statusText = order.Status switch
            {
                OrderStatus.Pending => "Sipariş Alındı",
                OrderStatus.Completed => "Ödeme Tamamlandı",
                OrderStatus.Failed => "İptal Edildi",
                OrderStatus.Processing => "Hazırlanıyor",
                OrderStatus.Shipped => "Kargoda",
                OrderStatus.Delivered => "Teslim Edildi",
                _ => "Bilinmiyor"
            };

            var statusBadgeClass = order.Status switch
            {
                OrderStatus.Completed or OrderStatus.Delivered => "bg-success",
                OrderStatus.Failed => "bg-danger",
                OrderStatus.Shipped => "bg-info pulse-badge",
                OrderStatus.Processing => "bg-primary pulse-badge",
                _ => "bg-warning text-dark"
            };

            <div class="card mb-5 shadow-sm border-0 overflow-hidden order-card-main">
                <div class="card-header bg-white border-bottom d-flex justify-content-between align-items-center pt-3 px-4">
                    <div>
                        <strong class="fs-5 text-dark">Sipariş #@order.Id</strong>
                        <span class="text-muted ms-2 small">@order.OrderedAt.ToString("dd MMMM yyyy HH:mm")</span>
                    </div>
                    <span class="badge rounded-pill px-3 py-2 @statusBadgeClass">
                        @statusText
                    </span>
                </div>
                <div class="card-body px-4 pb-4">
                    <!-- Sipariş Takip Adımları -->
                    @if (order.Status != OrderStatus.Failed)
                    {
                        <div class="order-tracking my-5">
                            <div class="steps">
                                <div class="step @(order.Status == OrderStatus.Completed || order.Status == OrderStatus.Processing || order.Status == OrderStatus.Shipped || order.Status == OrderStatus.Delivered ? "completed" : "active")">
                                    <div class="step-icon"><i class="fas fa-check-circle"></i></div>
                                    <div class="step-label">Alındı</div>
                                </div>
                                <div class="step @(order.Status == OrderStatus.Shipped || order.Status == OrderStatus.Delivered ? "completed" : order.Status == OrderStatus.Processing ? "active" : "")">
                                    <div class="step-icon"><i class="fas fa-cog"></i></div>
                                    <div class="step-label">Hazırlanıyor</div>
                                </div>
                                <div class="step @(order.Status == OrderStatus.Delivered ? "completed" : order.Status == OrderStatus.Shipped ? "active" : "")">
                                    <div class="step-icon"><i class="fas fa-truck"></i></div>
                                    <div class="step-label">Kargoda</div>
                                </div>
                                <div class="step @(order.Status == OrderStatus.Delivered ? "completed" : "")">
                                    <div class="step-icon"><i class="fas fa-box-open"></i></div>
                                    <div class="step-label">Teslim Edildi</div>
                                </div>
                            </div>
                        </div>
                    }

                    <div class="row g-4">
                        <div class="col-md-7">
                            <h6 class="text-secondary text-uppercase small fw-bold mb-3 d-flex align-items-center">
                                <i class="fas fa-boxes me-2"></i> Satın Alınan Ürünler
                            </h6>
                            <div class="order-items border rounded-3 p-3 bg-light">
                                @foreach (var item in order.Lines)
                                {
                                    <div class="order-item-row mb-3 pb-3 border-bottom last-border-0">
                                        <div class="d-flex justify-content-between align-items-center">
                                            <div class="d-flex align-items-center">
                                                <img src="@item.Product.ImageURL" class="rounded border me-3" style="width: 60px; height: 60px; object-fit: contain; background: white;" alt="@item.Product.Name" />
                                                <div>
                                                    <div class="fw-bold text-dark">@item.Product.Name</div>
                                                    <div class="text-secondary small">@item.Quantity Adet x @item.Product.Price.ToString("C2")</div>
                                                </div>
                                            </div>
                                            <div class="text-end">
                                                <div class="fw-bold fs-6">@((item.Product.Price * item.Quantity).ToString("C2"))</div>
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>

                        <div class="col-md-5">
                            <div class="summary-card border rounded-3 p-4 h-100 shadow-sm bg-white">
                                <h6 class="text-secondary text-uppercase small fw-bold mb-3 d-flex align-items-center">
                                    <i class="fas fa-file-invoice-dollar me-2"></i> Hesap Özeti
                                </h6>
                                
                                <div class="price-summary">
                                    <div class="d-flex justify-content-between mb-2 small text-dark">
                                        <span>Ara Toplam</span>
                                        <span class="fw-bold">@order.Lines.Sum(x => x.Product.Price * x.Quantity).ToString("C2")</span>
                                    </div>
                                    <div class="d-flex justify-content-between mb-2 small text-dark">
                                        <span>Kargo Ücreti</span>
                                        <span class="fw-bold text-success font-monospace">Ücretsiz</span>
                                    </div>
                                    <hr class="my-3">
                                    <div class="d-flex justify-content-between align-items-center">
                                        <span class="h5 mb-0 fw-bold">Toplam</span>
                                        <span class="h4 mb-0 text-primary fw-bold">@order.Lines.Sum(x => x.Product.Price * x.Quantity).ToString("C2")</span>
                                    </div>
                                </div>

                                <div class="mt-4 pt-4 border-top">
                                    <h6 class="text-secondary text-uppercase small fw-bold mb-3 d-flex align-items-center">
                                        <i class="fas fa-map-marker-alt me-2"></i> Teslimat Adresi
                                    </h6>
                                    <div class="small text-dark">
                                        <div class="fw-bold mb-1">@order.ShippingFirstName @order.ShippingLastName</div>
                                        <div class="text-muted mb-2"><i class="fas fa-phone me-1"></i> @order.ShippingPhone</div>
                                        <div class="bg-light p-2 rounded border-0 text-secondary" style="font-size: 13px;">
                                            @order.ShippingAddressDetail, @order.ShippingNeighborhood<br />
                                            <strong>@order.ShippingDistrict / @order.ShippingProvince</strong> @order.ShippingPostalCode
                                        </div>
                                    </div>
                                </div>

                                @if (!string.IsNullOrEmpty(order.TrackingNumber))
                                {
                                    <div class="mt-4 pt-4 border-top">
                                        <h6 class="text-info text-uppercase small fw-bold mb-3 d-flex align-items-center">
                                            <i class="fas fa-truck-fast me-2"></i> Kargo Bilgileri
                                        </h6>
                                        <div class="bg-info bg-opacity-10 p-3 rounded">
                                            <div class="d-flex justify-content-between mb-1">
                                                <span class="small text-muted">Firma:</span>
                                                <span class="small fw-bold">@order.CargoCompany</span>
                                            </div>
                                            <div class="d-flex justify-content-between">
                                                <span class="small text-muted">Takip No:</span>
                                                <span class="small fw-bold text-primary">@order.TrackingNumber</span>
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    }
    else
    {
        <div class="text-center py-5 bg-white rounded shadow-sm border mt-4">
            <div class="mb-4"><i class="fas fa-box-open fa-5x text-light opacity-50"></i></div>
            <h4 class="text-muted fw-light">Henüz bir siparişiniz bulunmamaktadır.</h4>
            <p class="text-secondary mb-4">Harika oyun ve sistemlerimize göz atarak hemen alışverişe başlayabilirsin.</p>
            <a href="/" class="btn btn-primary px-5 py-3 rounded-pill shadow-sm fw-bold">ALIŞVERİŞE BAŞLA</a>
        </div>
    }
</div>

<style>
    body { background-color: #f8f9fa; }
    .order-card-main { transition: all 0.25s ease-in-out; border-radius: 20px; border: 1px solid rgba(0,0,0,.05); }
    .order-card-main:hover { transform: translateY(-5px); box-shadow: 0 1rem 3rem rgba(0,0,0,.1) !important; }
    .last-border-0:last-child { border-bottom: 0 !important; margin-bottom: 0 !important; padding-bottom: 0 !important; }
    
    .order-tracking { padding: 10px 0; }
    .steps { display: flex; justify-content: space-between; position: relative; margin: 0 auto; max-width: 650px; }
    .steps::before { content: ''; position: absolute; top: 20px; left: 0; right: 0; height: 4px; background: #eee; z-index: 0; border-radius: 10px; }
    .step { flex: 1; text-align: center; position: relative; z-index: 1; }
    .step-icon { width: 44px; height: 44px; border-radius: 50%; background: #fff; border: 3px solid #eee; color: #ccc; display: flex; align-items: center; justify-content: center; margin: 0 auto 12px; font-size: 18px; transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275); }
    
    .step.completed .step-icon { background: #198754; border-color: #198754; color: white; transform: scale(1.1); }
    .step.active .step-icon { background: #fff; border-color: #0d6efd; color: #0d6efd; box-shadow: 0 0 20px rgba(13,110,253,0.3); transform: scale(1.2); }
    
    .step-label { font-size: 13px; color: #999; font-weight: 500; }
    .step.completed .step-label { color: #198754; font-weight: 600; }
    .step.active .step-label { color: #0d6efd; font-weight: 700; }
    
    /* Pulse Animations */
    .pulse-badge { animation: pulse-blue-shadow 2s infinite; }
    .bg-info.pulse-badge { animation: pulse-info-shadow 2s infinite; }
    .step.active .step-icon { animation: pulse-blue-step 2s infinite; }

    @@keyframes pulse-blue-shadow {
        0% { box-shadow: 0 0 0 0 rgba(13, 110, 253, 0.4); }
        70% { box-shadow: 0 0 0 10px rgba(13, 110, 253, 0); }
        100% { box-shadow: 0 0 0 0 rgba(13, 110, 253, 0); }
    }

    @@keyframes pulse-info-shadow {
        0% { box-shadow: 0 0 0 0 rgba(13, 202, 240, 0.4); }
        70% { box-shadow: 0 0 0 10px rgba(13, 202, 240, 0); }
        100% { box-shadow: 0 0 0 0 rgba(13, 202, 240, 0); }
    }

    @@keyframes pulse-blue-step {
        0% { box-shadow: 0 0 0 0 rgba(13, 110, 253, 0.2); transform: scale(1.2); }
        70% { box-shadow: 0 0 0 15px rgba(13, 110, 253, 0); transform: scale(1.2); }
        100% { box-shadow: 0 0 0 0 rgba(13, 110, 253, 0); transform: scale(1.2); }
    }

    /* Icon Specific Animations */
    .step.active .fa-cog { animation: spin 2s linear infinite; }
    .step.active .fa-truck { animation: truck-bounce 1.2s ease-in-out infinite; }

    @@keyframes spin { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }
    @@keyframes truck-bounce {
        0%, 100% { transform: translateX(0); }
        25% { transform: translateX(4px) translateY(-1px); }
        50% { transform: translateX(0); }
        75% { transform: translateX(-3px) translateY(1px); }
    }

    @@media (max-width: 768px) {
        .steps { flex-direction: column; text-align: left; padding-left: 20px; }
        .steps::before { left: 40px; top: 0; bottom: 0; width: 4px; height: auto; }
        .step { display: flex; align-items: center; margin-bottom: 30px; text-align: left; }
        .step-icon { margin: 0 20px 0 0; }
        .step-label { margin-top: 0; font-size: 14px; }
        .summary-card { margin-top: 20px; }
    }
</style>
