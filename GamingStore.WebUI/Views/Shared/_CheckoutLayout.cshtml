<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - GamingStore</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css" />
    <style>
        body { background-color: #f5f5f5; color: #484848; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; }
        .checkout-header { background: #fff; border-bottom: 1px solid #e6e6e6; padding: 15px 0; margin-bottom: 30px; }
        .checkout-logo { font-size: 24px; font-weight: bold; color: #ff6000; text-decoration: none; }
        .secure-badge { color: #5cb85c; font-size: 14px; font-weight: 600; }
        .user-initials { width: 35px; height: 35px; background: #eee; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: bold; color: #666; font-size: 13px; }
    </style>
</head>
<body>
    <header class="checkout-header">
        <div class="container">
            <div class="d-flex justify-content-between align-items-center">
                <a href="/" class="checkout-logo">gamingstore</a>
                <div class="secure-badge">
                    <i class="fa-solid fa-shield-halved me-1"></i> Güvenli Alışveriş
                </div>
                <div class="user-initials shadow-sm">
                    @if (User.Identity.IsAuthenticated)
                    {
                        var name = User.Identity.Name ?? "";
                        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
                        var initials = parts.Length > 1 
                            ? (parts[0][0].ToString() + parts[parts.Length - 1][0].ToString()).ToUpper() 
                            : (parts.Length > 0 ? parts[0].Substring(0, Math.Min(2, parts[0].Length)).ToUpper() : "?");
                        @initials
                    }
                    else
                    {
                        <i class="fa-solid fa-user"></i>
                    }
                </div>
            </div>
        </div>
    </header>

    <div class="container">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
